# =============================================================================
# AAAgents Community Edition - Environment Variables
# Copy this file to .env and fill in your actual values
# =============================================================================

# --- Backend Configuration ---
# ENGINE_PORT=8001
# ENGINE_HOST=0.0.0.0

# =============================================================================
# TRADING & DATA 
# =============================================================================

# Alpaca API Keys (Paper or Live)
# Get your keys from: https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Polygon (Optional for Market Data)
POLYGON_API_KEY=

# =============================================================================
# LLM & AI PROVIDERS
# =============================================================================

# LLM Provider: Set to "ollama", "claude", "openai", or "gemini"
LLM_PROVIDER=ollama

# Anthropic Claude 
ANTHROPIC_API_KEY=

# OpenAI ChatGPT
OPENAI_API_KEY=

# Google Gemini
GEMINI_API_KEY=

# Ollama local endpoint
OLLAMA_BASE_URL=http://ollama:11434

# =============================================================================
# SYSTEM SETTINGS
# =============================================================================
ENABLE_LIVE_TRADING=false
REDIS_DISABLED=true
